# ============================================================
# Microsoft Azure AD / Graph API
# ============================================================
# Azure AD App Registration (required for API access)
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# SharePoint user credentials (for device code / ROPC flow)
SP_USERNAME=dev_Partner02@mantan.co.jp
SP_PASSWORD=your-password-here

# ============================================================
# SharePoint Configuration
# ============================================================
SHAREPOINT_HOSTNAME=ogakame001.sharepoint.com

# Graph Search API (application permissions): region is required
# Examples: NAM, EUR, APC, JPN — try JPN or APC if search returns 400
GRAPH_SEARCH_REGION=APC

# Comma-separated site names to crawl (empty = all sites)
# Example: TCS事業,海外事業部,エネルギー事業部
TARGET_SITES=

# Initial pilot site (for first-run testing)
PILOT_SITE=SIOジャパン

# ============================================================
# Gemini API
# ============================================================
GEMINI_API_KEY=your-gemini-api-key-here
# ListModels / generate_content で使える名前（例: gemini-2.5-flash, gemini-2.5-pro）
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# ============================================================
# Processing Settings
# ============================================================
# Max file size to process (MB)
MAX_FILE_SIZE_MB=50

# Chunk settings (tokens)
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Number of chunks to retrieve for RAG
TOP_K=5
# ベクトル RAG の類似度しきい値（0〜1、高いほど厳しい）。既定 0.5。厳しすぎてヒット 0 なら 0.35〜0.45 を試す。
RAG_MIN_SCORE=0.5

# Hybrid mode (search → top files only → Gemini; no vector index)
HYBRID_TOP_FILES=5
HYBRID_MAX_CONTEXT_CHARS=120000

# Parallel download workers
MAX_WORKERS=10

# Embedding batch size
BATCH_SIZE=50

# ============================================================
# Storage Paths
# ============================================================
DATA_DIR=./data
VECTOR_DB_DIR=./data/vector_db
METADATA_DB_PATH=./data/metadata.db
DOWNLOAD_DIR=./data/downloads
TOKEN_CACHE_PATH=./data/token_cache.bin

# ============================================================
# Sync Settings
# ============================================================
# Daily sync time (24h format)
SYNC_TIME=02:00

# Days to look back for initial delta (0 = full sync)
DELTA_DAYS=0

# ============================================================
# HTTP API（Next.js UI 用 FastAPI）
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
# CORS 許可オリジン（カンマ区切り）
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
